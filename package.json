{
  "name": "healthviewos",
  "version": "0.0.0",
  "private": true,
  "description": "A visual OS for personal health.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm --filter @healthviewos/web dev",
    "dev:web": "pnpm --filter @healthviewos/web dev",
    "build": "pnpm --recursive build",
    "lint": "pnpm --recursive lint",
    "sync:openhuman-atlas": "node scripts/sync-openhuman-atlas-assets.mjs",
    "test": "pnpm --recursive --if-present test",
    "typecheck": "pnpm --recursive --if-present typecheck"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
