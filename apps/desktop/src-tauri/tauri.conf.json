{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HealthView OS",
  "version": "0.0.0",
  "identifier": "me.healthviewos.desktop",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HealthView OS",
        "width": 1280,
        "height": 860,
        "minWidth": 390,
        "minHeight": 560,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
